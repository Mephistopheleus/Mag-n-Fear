api_keys:
  binance_testnet_api_key: mYVqkHL4mSwEiHrHC6PaurPUHOV7auYwXXpkSmMX7hSSY8KT7teRmbQV6BY9YD3i
  binance_testnet_api_secret: ym3B6HkI6ervEsc4We0jr47O51tueW8CRTqpU6TxbpwzKsxAtLWtGKtbeUQ86aBf
bot:
  exchanges:
  - binance_futures
  mode: shadow
  name: HybridMathScalper
  version: 0.1.0
data:
  correlation_symbol: BTCUSDT
  order_book_depth: 20
  primary_symbol: DOGEUSDT
  snapshot_interval_sec: 1
  symbols:
  - DOGEUSDT
  - BTCUSDT
  timeframes:
  - 1m
  - 5m
executor:
  default_order_type: limit
  limit_order_timeout_sec: 30
  trailing_stop:
    activation_pct: 0.5
    enabled: true
    trail_distance_pct: 0.3
  use_ioc: false
logging:
  cards_path: data_storage/cards
  level: INFO
  log_path: logs/bot.log
  rotation: 1 day
  save_cards: true
matrix:
  decay_factor: 0.95
  price_bins_count: 50
  time_bins_count: 60
  time_horizon_sec: 300
risk:
  commission_buffer: 0.0003
  commission_rate: 0.0002
  flat_market_discount: 0.7
  kelly_fraction: 0.25
  learning_mode: true
  max_correlation_exposure: 0.8
  max_daily_loss_pct: 2.0
  max_position_size_usd: 33
  min_profit_threshold: 0.05
  min_reward_ratio: 1.5
  risk_per_trade_pct: 0.5
  slippage_buffer: 0.0005
  trading_balance_usd: 50.0
scenario:
  entry_delay_sec: 2
  max_slippage_bps: 10
  min_confidence_threshold: 0.65
storage:
  db_path: data_storage/history.db
  matrix_cache_path: data_storage/matrix_cache.parquet
  type: sqlite
tuner:
  confidence_factors:
    matrix: 0.335
    mean_reversion: 0.335
    order_flow: 0.335
    trend: 0.335
    volatility: 0.335
  impact_threshold: 0.05
  min_trades_for_update: 50
